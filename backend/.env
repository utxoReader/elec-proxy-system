# ==========================================
# 桐叶售电代理系统 — 本地开发环境默认配置
# ==========================================

APP_NAME=桐叶售电代理系统
APP_VERSION=0.1.0
APP_ENV=development

# PostgreSQL 服务由 docker-compose.yml 提供
DATABASE_URL=postgresql+pg8000://tongye:tongye@localhost:5434/tongye

# JWT（开发环境默认值，生产必须替换）
SECRET_KEY=dev-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256

CORS_ORIGINS=["*"]
