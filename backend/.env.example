# ==========================================
# 桐叶售电代理系统 — 后端环境变量配置示例
# 复制本文件为 .env 后填入真实值
# ==========================================
# ⚠️ 安全警告：以下默认值仅用于本地开发。
#    生产环境必须修改 SECRET_KEY、DATABASE_URL 和 CORS_ORIGINS。
# ==========================================

# ---------- 应用 ----------
APP_NAME=桐叶售电代理系统
APP_VERSION=0.1.0
APP_ENV=development                     # development | production | testing

# ---------- 数据库（生产环境必须修改密码） ----------
DATABASE_URL=postgresql+psycopg2://tongye:tongye@localhost:5432/tongye

# ---------- JWT 安全密钥（生产环境必须修改） ----------
# SECRET_KEY 如不设置，将自动生成随机密钥（重启后 token 失效）
# SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=1440        # Token 有效期（分钟），默认 24 小时
ALGORITHM=HS256

# ---------- CORS（生产环境限制为具体前端域名） ----------
# 开发环境: http://localhost:5173,http://localhost:3000
# 生产环境: https://your-domain.com
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
